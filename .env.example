# ──────────────────────────────────────────
# Server
# ──────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ──────────────────────────────────────────
# MongoDB
# ──────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# REDIS_CA=          # Optional: path to CA bundle for TLS

# ──────────────────────────────────────────
# JWT / Auth
# ──────────────────────────────────────────
ACCESS_TOKEN_SECRET=your_secure_access_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=your_secure_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRY=10d

# ──────────────────────────────────────────
# CORS
# ──────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────────────
# Cloudinary (avatars + cover images)
# ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────
# Azure Blob Storage (HLS video + subtitles)
# ──────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_CONTAINER_NAME=videos
AZURE_SAS_TOKEN=

# ──────────────────────────────────────────
# Whisper Transcription
# ──────────────────────────────────────────
WHISPER_MODEL=base
# Options: tiny (39M), base (74M), small (244M), medium (769M), large (1550M)
